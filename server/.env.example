# =============================================================================
# Cabinet Conseil Algérie — Variables d'environnement
# Copier ce fichier en .env à la racine ET/OU dans /server selon votre setup
# =============================================================================

# Base de données MySQL (compatible o2switch)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://user:password@localhost:3306/cabinet_conseil"

# Serveur API
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Auth admin (JWT)
# Générer un secret fort: openssl rand -base64 48
JWT_SECRET="changez-moi-par-un-secret-long-et-aleatoire"
JWT_EXPIRES_IN=7d

# Compte admin initial (seed)
# ADMIN_PASSWORD_HASH: hash bcrypt du mot de passe (généré au seed ou via bcrypt)
ADMIN_EMAIL="admin@cabinet-conseil.dz"
ADMIN_PASSWORD_HASH="$2b$10$placeholder_remplace_par_hash_bcrypt"

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5

# SMTP (Nodemailer) — notification leads + confirmation
SMTP_HOST=mail.votredomaine.dz
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@votredomaine.dz
SMTP_PASS=mot-de-passe-smtp
SMTP_FROM="Cabinet Conseil <noreply@votredomaine.dz>"
SMTP_NOTIFY_TO=contact@votredomaine.dz

# Freepik API (stock photos — clé serveur uniquement, jamais côté client)
FREEPIK_API_KEY=
